{
	"name": "@rodavel/tanstack-mdx-tree",
	"version": "0.2.1",
	"description": "Typed navigation trees from MDX content colocated with TanStack Router routes",
	"type": "module",
	"keywords": [
		"vite",
		"vite-plugin",
		"content-tree",
		"frontmatter",
		"navigation"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=18"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"bin": {
		"content-tree": "./dist/cli.js"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"prepublishOnly": "bun run build && bun run test",
		"changeset": "changeset",
		"release": "changeset publish",
		"prepare": "husky"
	},
	"peerDependencies": {
		"vite": ">=5"
	},
	"dependencies": {
		"gray-matter": "^4.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@changesets/cli": "^2.30.0",
		"@types/node": "^25.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"tsup": "^8.4.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0",
		"vitest": "^3.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/rodavel-labs/vite-plugin-content-tree.git"
	},
	"bugs": {
		"url": "https://github.com/rodavel-labs/vite-plugin-content-tree/issues"
	},
	"homepage": "https://github.com/rodavel-labs/vite-plugin-content-tree#readme",
	"license": "MIT",
	"lint-staged": {
		"*.{ts,json}": "biome check --write --no-errors-on-unmatched"
	}
}
